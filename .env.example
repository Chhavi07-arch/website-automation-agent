# ============================================================================
#  Website Automation Agent — example configuration
#  Copy this file to `.env` and adjust values as needed:  cp .env.example .env
# ============================================================================

# --- Browser settings ---
BROWSER_TYPE=chromium          # chromium | firefox | webkit
HEADLESS=false                 # true = no visible window (faster, for CI)
SLOW_MO=50                     # ms delay added to each Playwright action (demo-friendly)
BROWSER_LOCALE=en-US           # realistic locale reduces anti-bot walls (e.g. Google CAPTCHA)
# BROWSER_UA=                   # custom User-Agent; leave unset for a realistic default, set empty for Playwright default

# --- Timeouts (milliseconds) ---
PAGE_LOAD_TIMEOUT=30000        # max wait for a page to load
ELEMENT_TIMEOUT=10000          # max wait for a single element
ACTION_DELAY=500               # pause between consecutive actions

# --- Form fill values (used by FILL_SHADCN_FORM) ---
# The shadcn "name" field is actually the *username* input — use a username, not a full name.
USERNAME=chhavi_ahlawat
FORM_DESCRIPTION=A first-year CS student building browser automation agents.

# --- Target URL (used by FILL_SHADCN_FORM) ---
TARGET_URL=https://ui.shadcn.com/docs/forms/react-hook-form

# --- Active goal — switch workflows WITHOUT touching code ---
# Options: FILL_SHADCN_FORM | SEARCH_GOOGLE | SEARCH_GITHUB
GOAL=FILL_SHADCN_FORM

# --- Search query values ---
GOOGLE_QUERY=Playwright browser automation
GITHUB_QUERY=playwright

# --- Resilience / retry tuning (read by config.retry) ---
RETRY_COUNT=3                  # max attempts for retryable element actions
NAV_RETRY_COUNT=2              # max attempts for NAVIGATE (bounded — never infinite)
RETRY_BASE_DELAY_MS=500        # first backoff delay; doubles each attempt (500→1000→2000)

# --- Logging ---
LOG_LEVEL=info                 # error | warn | recovery | plan | observe | think | act | verify | info | debug
LOG_TO_FILE=true               # also write logs to logs/agent.log + logs/errors.log

# --- Demo Mode (viva / recruiter demos) — OFF by default, fully backward compatible ---
KEEP_BROWSER_OPEN=false        # true = keep the browser open after the run (success OR failure)
DEMO_PAUSE_MS=15000            # ms to hold the browser open (only applies when KEEP_BROWSER_OPEN=true)
DEMO_MODE=false                # true = also slow actions slightly + print 🎬 banners
# Turn it on for a demo:  KEEP_BROWSER_OPEN=true npm run github
# Every run also saves before-task / after-task screenshots to screenshots/.

# --- HTML run report ---
REPORT=true                    # write reports/report_<ts>.html after each run

# --- AI Planner (Phase 4A) — converts a natural-language goal into task JSON ---
# Run with:  GOAL=AI_PLAN AI_GOAL="search github for playwright" npm run ai
PLANNER_MODE=mock              # mock (offline, no key) | openrouter
AI_GOAL=                       # natural-language goal for GOAL=AI_PLAN
OPENROUTER_API_KEY=            # required only for PLANNER_MODE=openrouter
OPENROUTER_MODEL=deepseek/deepseek-chat-v3-0324:free
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1
OPENROUTER_TIMEOUT_MS=30000
