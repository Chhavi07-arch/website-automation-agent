# ============================================================================
#  Website Automation Agent — example configuration
#  Copy this file to `.env` and adjust values as needed:  cp .env.example .env
# ============================================================================

# --- Browser settings ---
BROWSER_TYPE=chromium          # chromium | firefox | webkit
HEADLESS=false                 # true = no visible window (faster, for CI)
SLOW_MO=50                     # ms delay added to each Playwright action (demo-friendly)

# --- Timeouts (milliseconds) ---
PAGE_LOAD_TIMEOUT=30000        # max wait for a page to load
ELEMENT_TIMEOUT=10000          # max wait for a single element
ACTION_DELAY=500               # pause between consecutive actions

# --- Form fill values (used by FILL_SHADCN_FORM) ---
FORM_NAME=Jane Doe
FORM_DESCRIPTION=This is an automated description filled by the Website Automation Agent.

# --- Target URL (used by FILL_SHADCN_FORM) ---
TARGET_URL=https://ui.shadcn.com/docs/forms/react-hook-form

# --- Active goal — switch workflows WITHOUT touching code ---
# Options: FILL_SHADCN_FORM | SEARCH_GOOGLE | SEARCH_GITHUB
GOAL=FILL_SHADCN_FORM

# --- Search query values ---
GOOGLE_QUERY=Playwright browser automation
GITHUB_QUERY=playwright

# --- Resilience / retry tuning (read by config.retry) ---
RETRY_COUNT=3                  # max attempts for retryable element actions
NAV_RETRY_COUNT=2              # max attempts for NAVIGATE (bounded — never infinite)
RETRY_BASE_DELAY_MS=500        # first backoff delay; doubles each attempt (500→1000→2000)

# --- Logging ---
LOG_LEVEL=info                 # error | warn | recovery | plan | observe | think | act | verify | info | debug
LOG_TO_FILE=true               # also write logs to logs/agent.log + logs/errors.log
