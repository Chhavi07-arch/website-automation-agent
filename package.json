{
  "name": "website-automation-agent",
  "version": "1.0.0",
  "description": "Intelligent browser automation agent framework inspired by Browser Use",
  "main": "src/index.js",
  "type": "module",
  "scripts": {
    "start": "node src/index.js",
    "dev": "node --watch src/index.js",
    "test": "node tests/resilience.test.mjs && node tests/github-verification.test.mjs && node tests/google-verification.test.mjs",
    "shadcn": "cross-env GOAL=FILL_SHADCN_FORM node src/index.js",
    "google": "cross-env GOAL=SEARCH_GOOGLE node src/index.js",
    "github": "cross-env GOAL=SEARCH_GITHUB node src/index.js",
    "postinstall": "playwright install chromium"
  },
  "dependencies": {
    "dotenv": "^16.4.5",
    "playwright": "^1.44.0",
    "winston": "^3.13.0"
  },
  "devDependencies": {
    "cross-env": "^7.0.3"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "keywords": [
    "browser-automation",
    "playwright",
    "agent",
    "web-scraping"
  ],
  "author": "",
  "license": "MIT"
}
